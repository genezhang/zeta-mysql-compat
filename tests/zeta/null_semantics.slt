# NULL semantics over the MySQL wire — IS NULL / IS NOT NULL, three-valued
# logic in AND/OR/NOT, NULL handling in WHERE / GROUP BY / DISTINCT, and
# COALESCE / NULLIF.
#
# These are some of the easiest places for a wire shim to diverge from
# real MySQL because they're the rare cases where MySQL and PG already
# agree on the semantics — the shim just has to not get in the way.

statement ok
DROP TABLE IF EXISTS t_null

statement ok
CREATE TABLE t_null (id INT PRIMARY KEY, a INT, b INT)

statement ok
INSERT INTO t_null VALUES
  (1, 1, 1),
  (2, 1, NULL),
  (3, NULL, 1),
  (4, NULL, NULL),
  (5, 0, 0)

# IS NULL / IS NOT NULL.
query I
SELECT COUNT(*) FROM t_null WHERE a IS NULL
----
2

query I
SELECT COUNT(*) FROM t_null WHERE a IS NOT NULL
----
3

# Three-valued logic — `= NULL` is never true, even for NULL itself.
query I
SELECT COUNT(*) FROM t_null WHERE a = NULL
----
0

query I
SELECT COUNT(*) FROM t_null WHERE a <> NULL
----
0

# AND / OR with a NULL operand.
# (1 AND NULL) → NULL → falsy in WHERE. Row 4 (a=NULL,b=NULL) and row 3
# (a=NULL,b=1) match because b=1 fails first AND, so NULL doesn't even matter.
query I
SELECT COUNT(*) FROM t_null WHERE a = 1 AND b = 1
----
1

# (1 OR NULL) → 1 → truthy. (NULL OR NULL) → NULL → falsy.
# Row 1: a=1 → match. Row 2: a=1 → match. Row 5: a=0 OR b=0 → 0 OR 0 → 0 → no.
query I
SELECT COUNT(*) FROM t_null WHERE a = 1 OR b = 1
----
3

# NOT (NULL) → NULL → falsy. NOT applied to a row where the inner expression
# is NULL still gives no match.
query I
SELECT COUNT(*) FROM t_null WHERE NOT (a = 1)
----
1

# COALESCE — first non-NULL.
query I
SELECT COALESCE(NULL, NULL, 42)
----
42

query I
SELECT COALESCE(NULL, 7, 42)
----
7

query II rowsort
SELECT id, COALESCE(a, -1) FROM t_null
----
1 1
2 1
3 -1
4 -1
5 0

# NULLIF — NULL when args equal, else first arg.
query I
SELECT NULLIF(5, 5)
----
NULL

query I
SELECT NULLIF(5, 7)
----
5

# DISTINCT treats NULLs as equal — should produce one NULL row.
query I rowsort
SELECT DISTINCT a FROM t_null
----
0
1
NULL

# GROUP BY also groups NULLs together.
query II rowsort
SELECT a, COUNT(*) FROM t_null GROUP BY a
----
0 1
1 2
NULL 2

# IN with a NULL on the right — `x IN (NULL, ...)` is NULL when x doesn't
# match any non-NULL list entry, never true for the NULL alone.
query I
SELECT COUNT(*) FROM t_null WHERE a IN (1, NULL)
----
2

query I
SELECT COUNT(*) FROM t_null WHERE a NOT IN (1, NULL)
----
0

statement ok
DROP TABLE t_null
