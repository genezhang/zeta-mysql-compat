# SAVEPOINT / ROLLBACK TO SAVEPOINT / RELEASE SAVEPOINT over the MySQL
# wire. These ride on top of the multi-statement txn machinery added by
# zeta #961; SAVEPOINT delegates to `Transaction::savepoint` (write-buffer
# snapshots), so ROLLBACK TO SAVEPOINT actually undoes writes made after
# the savepoint.

statement ok
DROP TABLE IF EXISTS sp_t

statement ok
CREATE TABLE sp_t (id INT PRIMARY KEY, name VARCHAR(50))

statement ok
INSERT INTO sp_t VALUES (1, 'pre')

statement ok
BEGIN

statement ok
INSERT INTO sp_t VALUES (2, 'before-sp')

statement ok
SAVEPOINT sp1

statement ok
INSERT INTO sp_t VALUES (3, 'after-sp')

# Pre-rollback: txn sees its own writes (rows 1,2,3).
query IT rowsort
SELECT id, name FROM sp_t
----
1 pre
2 before-sp
3 after-sp

statement ok
ROLLBACK TO SAVEPOINT sp1

# Row 3 (inserted after sp1) is gone; row 2 (before sp1) survives.
query IT rowsort
SELECT id, name FROM sp_t
----
1 pre
2 before-sp

statement ok
RELEASE SAVEPOINT sp1

statement ok
COMMIT

# After commit: rows 1 and 2 are durable.
query IT rowsort
SELECT id, name FROM sp_t
----
1 pre
2 before-sp

statement ok
DROP TABLE sp_t
