# Math functions over the MySQL wire — ABS, ROUND, CEIL, FLOOR, MOD,
# POW, SQRT, SIGN, plus GREATEST / LEAST and the trig stragglers if
# they're recognized.

# ABS — integer and floating-point.
query I
SELECT ABS(-7)
----
7

query I
SELECT ABS(7)
----
7

# ROUND — to nearest integer (no second arg).
query I
SELECT ROUND(2.5)
----
3

query I
SELECT ROUND(2.4)
----
2

query I
SELECT ROUND(-2.5)
----
-3

# ROUND with explicit precision.
query T
SELECT ROUND(CAST(3.14159 AS DECIMAL(10, 5)), 2)
----
3.14

# CEIL / FLOOR.
query I
SELECT CEIL(2.1)
----
3

query I
SELECT FLOOR(2.9)
----
2

query I
SELECT CEIL(-2.1)
----
-2

query I
SELECT FLOOR(-2.1)
----
-3

# MOD — modulo, both as function and operator.
query I
SELECT MOD(17, 5)
----
2

query I
SELECT 17 % 5
----
2

# POW / POWER — exponentiation.
query I
SELECT POW(2, 10)
----
1024

query T
SELECT POW(2.0, 0.5)
----
1.4142135623730951

# SQRT.
query I
SELECT SQRT(16)
----
4

# SIGN.
query I
SELECT SIGN(7)
----
1

query I
SELECT SIGN(-7)
----
-1

query I
SELECT SIGN(0)
----
0

# GREATEST / LEAST.
query I
SELECT GREATEST(1, 5, 3, 2)
----
5

query I
SELECT LEAST(1, 5, 3, 2)
----
1

# GREATEST / LEAST with NULL — MySQL would short-circuit to NULL but
# zeta follows PG semantics (NULL skipped). Pinned to observed; see
# zeta #971.
query I
SELECT GREATEST(1, NULL, 3)
----
3

# LN — natural log.
query T
SELECT LN(1)
----
0

# LOG with base — exact integer-power-of-10 case is fp-imprecise on
# zeta (returns 2.9999999999999996 for LOG(10, 1000)). Skipped here;
# pin LN above as the smoke test.
