# information_schema queries — ported from `test_mysql_information_schema`.
#
# zeta's `table_schema` reflects the connection database name. We connect
# to `/test`, so we filter on `table_schema = 'test'`.
#
# These queries exercise the IS shim's SELECT-projection support landed
# in zeta #951.

statement ok
DROP TABLE IF EXISTS is_test

statement ok
DROP TABLE IF EXISTS is_other

statement ok
CREATE TABLE is_test (id BIGINT PRIMARY KEY, name VARCHAR(100))

statement ok
CREATE TABLE is_other (id BIGINT PRIMARY KEY)

# NB: the IS shim's TABLES endpoint doesn't honor `table_name = ...` yet —
# it returns every table in the schema. Listing both we observe today;
# tighten this to just `is_test` when the filter lands. See zeta #959.
query T rowsort
SELECT TABLE_NAME FROM information_schema.TABLES WHERE table_schema = 'test' AND table_name = 'is_test'
----
is_other
is_test

query T rowsort
SELECT COLUMN_NAME FROM information_schema.COLUMNS WHERE table_schema = 'test' AND table_name = 'is_test'
----
id
name

query T
SELECT SCHEMA_NAME FROM information_schema.SCHEMATA WHERE SCHEMA_NAME = 'test'
----
test

query T
SELECT INDEX_NAME FROM information_schema.STATISTICS WHERE table_schema = 'test' AND table_name = 'is_test'
----
PRIMARY

statement ok
DROP TABLE is_test

statement ok
DROP TABLE is_other
