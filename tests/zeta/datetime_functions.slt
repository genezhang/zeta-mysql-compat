# Date/time functions over the MySQL wire — DATE_ADD / DATE_SUB /
# DATEDIFF / ADDDATE / SUBDATE fixed in zeta #966 (rewritten in the
# parser converter to PG-style `+ INTERVAL` / `- INTERVAL` and
# `Date - Date` operators).

# CURRENT_DATE / CURRENT_TIMESTAMP / NOW return values — we can't pin
# their values, but can pin their types and that they return non-NULL.
query I
SELECT CASE WHEN CURRENT_DATE IS NULL THEN 0 ELSE 1 END
----
1

query I
SELECT CASE WHEN NOW() IS NULL THEN 0 ELSE 1 END
----
1

# PG-style + INTERVAL.
query T
SELECT DATE '2026-01-15' + INTERVAL '1 month'
----
2026-02-15 00:00:00

query T
SELECT TIMESTAMP '2026-01-15 12:00:00' + INTERVAL '90 minutes'
----
2026-01-15 13:30:00

# MySQL DATE_ADD / DATE_SUB — rewritten to + / - INTERVAL.
query T
SELECT DATE_ADD(DATE '2026-01-15', INTERVAL '7 days')
----
2026-01-22 00:00:00

query T
SELECT DATE_SUB(DATE '2026-01-15', INTERVAL '7 days')
----
2026-01-08 00:00:00

query T
SELECT DATE_ADD(TIMESTAMP '2026-01-15 12:00:00', INTERVAL '90 minutes')
----
2026-01-15 13:30:00

# ADDDATE / SUBDATE — MySQL aliases.
query T
SELECT ADDDATE(DATE '2026-01-15', INTERVAL '2 weeks')
----
2026-01-29 00:00:00

query T
SELECT SUBDATE(DATE '2026-01-15', INTERVAL '1 month')
----
2025-12-15 00:00:00

# DATEDIFF — MySQL semantics: integer day delta (d1 - d2).
query I
SELECT DATEDIFF(DATE '2026-02-15', DATE '2026-01-15')
----
31

query I
SELECT DATEDIFF(DATE '2026-01-15', DATE '2026-02-15')
----
-31

query I
SELECT DATEDIFF(DATE '2026-01-15', DATE '2026-01-15')
----
0

# DATEDIFF accepts TIMESTAMP too — both sides cast to DATE first.
query I
SELECT DATEDIFF(TIMESTAMP '2026-02-15 23:59:59', TIMESTAMP '2026-01-15 00:00:01')
----
31

# EXTRACT — already covered in types_datetime, repeated for completeness.
query I
SELECT EXTRACT(DOW FROM DATE '2026-01-15')
----
4

# DATE_TRUNC.
query T
SELECT DATE_TRUNC('hour', TIMESTAMP '2026-01-15 12:34:56')
----
2026-01-15 12:00:00

query T
SELECT DATE_TRUNC('year', TIMESTAMP '2026-01-15 12:34:56')
----
2026-01-01 00:00:00

# TO_CHAR — PG-style date formatting (MySQL has DATE_FORMAT instead).
query T
SELECT TO_CHAR(DATE '2026-01-15', 'YYYY-MM-DD')
----
2026-01-15

# Casting — DATE / TIMESTAMP literal parses.
query T
SELECT CAST('2026-01-15' AS DATE)
----
2026-01-15

query T
SELECT CAST('2026-01-15 12:34:56' AS TIMESTAMP)
----
2026-01-15 12:34:56
