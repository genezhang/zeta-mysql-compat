# Multi-statement transactions over the MySQL wire — fixed in zeta #961.
#
# Before the fix every statement auto-committed; ROLLBACK was a no-op.
# Now BEGIN / START TRANSACTION / COMMIT / ROLLBACK go through real
# per-session txn state in the MySQL shim, mirroring the PG wire.
# SAVEPOINT / RELEASE / ROLLBACK TO SAVEPOINT are routed through the
# txn's write-buffer snapshot API (see savepoints.slt).

statement ok
DROP TABLE IF EXISTS txn_t

statement ok
CREATE TABLE txn_t (id INT PRIMARY KEY, name VARCHAR(50))

statement ok
INSERT INTO txn_t VALUES (1, 'pre-commit')

# Baseline: one row.
query IT
SELECT id, name FROM txn_t
----
1 pre-commit

# COMMIT path — writes inside BEGIN/COMMIT are durable.
statement ok
BEGIN

statement ok
INSERT INTO txn_t VALUES (2, 'committed')

# In-txn read sees the txn's own writes.
query IT rowsort
SELECT id, name FROM txn_t
----
1 pre-commit
2 committed

statement ok
COMMIT

query IT rowsort
SELECT id, name FROM txn_t
----
1 pre-commit
2 committed

# ROLLBACK path — undoes writes made inside the txn.
statement ok
BEGIN

statement ok
INSERT INTO txn_t VALUES (3, 'rolled-back')

statement ok
UPDATE txn_t SET name = 'modified' WHERE id = 1

# In-txn read sees the txn's tentative writes.
query IT rowsort
SELECT id, name FROM txn_t
----
1 modified
2 committed
3 rolled-back

statement ok
ROLLBACK

# Post-rollback: only the originally-committed rows survive.
query IT rowsort
SELECT id, name FROM txn_t
----
1 pre-commit
2 committed

# START TRANSACTION is a synonym for BEGIN.
statement ok
START TRANSACTION

statement ok
INSERT INTO txn_t VALUES (4, 'st-tx')

statement ok
COMMIT

query IT rowsort
SELECT id, name FROM txn_t
----
1 pre-commit
2 committed
4 st-tx

# Stray COMMIT / ROLLBACK outside a txn are accepted as no-ops (matches
# real MySQL — the server warns but does not error).
statement ok
COMMIT

statement ok
ROLLBACK

statement ok
DROP TABLE txn_t
