# Multi-table UPDATE / DELETE over the MySQL wire — currently both
# dialects fail in different ways (zeta #973):
#   - PG-style `UPDATE ... FROM other` errors with "table not found:
#     other" (search_path not consulted in the FROM resolver).
#   - MySQL-style `UPDATE t1 JOIN t2 ON ... SET ...` errors with
#     "column not found: u.val" (parser accepts but qualified column
#     refs in SET aren't resolved through the JOIN aliases).
#
# Single-table UPDATE / DELETE work fine (covered in ddl_crud.slt /
# txn.slt). This file pins the multi-table rejections so a future fix
# lands as a noisy diff.

statement ok
DROP TABLE IF EXISTS udj_orders

statement ok
DROP TABLE IF EXISTS udj_users

statement ok
CREATE TABLE udj_users (id INT PRIMARY KEY, name VARCHAR(50), spend INT)

statement ok
CREATE TABLE udj_orders (id INT PRIMARY KEY, user_id INT, amount INT)

statement ok
INSERT INTO udj_users VALUES (1, 'Alice', 0)

statement ok
INSERT INTO udj_orders VALUES (10, 1, 100)

# PG-style UPDATE FROM — pinned to current rejection (#973).
statement error
UPDATE udj_users u SET spend = o.amount FROM udj_orders o WHERE o.user_id = u.id

# MySQL-style UPDATE JOIN — pinned to current rejection (#973).
statement error
UPDATE udj_users u JOIN udj_orders o ON o.user_id = u.id SET u.spend = u.spend + o.amount

# PG-style DELETE USING — pinned (#973).
statement error
DELETE FROM udj_orders USING udj_users WHERE udj_orders.user_id = udj_users.id AND udj_users.id = 1

# MySQL-style DELETE FROM with JOIN — silent no-op (#973). Returns
# OK but deletes nothing. Pinned: rows survive.
statement ok
DELETE o FROM udj_orders o JOIN udj_users u ON o.user_id = u.id WHERE u.id = 1

# All rows still present — confirms the no-op.
query I
SELECT COUNT(*) FROM udj_orders WHERE user_id = 1
----
1

statement ok
DROP TABLE udj_orders

statement ok
DROP TABLE udj_users
